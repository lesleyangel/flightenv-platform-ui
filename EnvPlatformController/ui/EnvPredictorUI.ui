         <string notr="true">/* ========== QTreeWidget 专属美化（仅视觉优化，不改动尺寸/布局） ========== */
QTreeWidget {
    font-family: &quot;微软雅黑&quot;;
    font-size: 12px;
    border: 1px solid #e0e3e9; /* 轻量级边框，提升质感 */
    border-radius: 6px; /* 微圆角，不影响布局 */
    background-color: #ffffff; /* 纯白背景，文字更清晰 */
    gridline-color: #f0f2f7; /* 网格线浅灰，弱化分割感 */
}

/* 节点样式：hover/选中态优化，不改动内边距/行高 */
QTreeWidget::item {
    font-family: &quot;微软雅黑&quot;;
    font-size: 12px;
    color: #333333; /* 正常文字色 */
    border-radius: 4px; /* 节点微圆角，不影响布局 */
}

/* 鼠标悬浮节点：浅蓝背景，不改动尺寸 */
QTreeWidget::item:hover {
    background-color: #ecf5ff; /* 淡蓝悬浮色，贴近系统风格 */
}

/* 选中节点：深蓝背景+白字，突出选中态 */
QTreeWidget::item:selected {
    background-color: #409eff; /* 主色调背景 */
    color: #ffffff; /* 白色文字，对比清晰 */
}

/* 选中且悬浮：加深背景色，保持交互反馈 */
QTreeWidget::item:selected:hover {
    background-color: #3385ff;
}

/* 禁用节点：浅灰文字，弱化显示 */
QTreeWidget::item:disabled {
    color: #909399;
    background-color: transparent;
}

/* 分支箭头（展开/折叠）：美化图标，不改动位置 */
QTreeWidget::branch {
    background-color: transparent; /* 箭头背景透明，不影响布局 */
}

/* 未展开分支箭头：浅灰右箭头 */
QTreeWidget::branch:has-children:!expanded {
    image: url(:/icons/arrow_right_gray.png); /* 建议用 12x12 浅灰右箭头图标 */
    image-position: center; /* 居中显示，不改动位置 */
}

/* 已展开分支箭头：主色调下箭头 */
QTreeWidget::branch:has-children:expanded {
    image: url(:/icons/arrow_down_blue.png); /* 建议用 12x12 蓝色下箭头图标 */
    image-position: center; /* 居中显示，不改动位置 */
}

/* 表头样式（若启用表头）：统一字体+浅灰背景 */
QTreeWidget QHeaderView::section {
    font-family: &quot;微软雅黑&quot;;
    font-size: 12px;
    font-weight: 500;
    color: #606266;
    background-color: #f8f9fa;
    border: none;
    border-bottom: 1px solid #e0e3e9;
    border-right: 1px solid #e0e3e9;
    border-radius: 0; /* 表头不圆角，避免布局偏移 */
}

/* 滚动条适配：美化滚动条，不影响布局 */
QTreeWidget QScrollBar:horizontal {
    height: 8px;
    background-color: transparent;
}

QTreeWidget QScrollBar:vertical {
    width: 8px;
    background-color: transparent;
}

QTreeWidget QScrollBar::handle {
    background-color: #dcdfe6;
    border-radius: 4px;
}

QTreeWidget QScrollBar::handle:hover {
    background-color: #c0c4cc;
}</string>
