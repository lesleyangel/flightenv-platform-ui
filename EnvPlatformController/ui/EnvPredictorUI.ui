  <property name="styleSheet">
   <string notr="true">/* 全局字体设置 */
* {
    font-family: &quot;微软雅黑&quot;;
    font-size: 14px;
}

/* 主窗口背景图（兼容低版本，移除background-size，用固定尺寸或布局适配） */
QMainWindow {
    /*background-image: url(:/ui/img/batthern-1920x1080.png);*/

	border-image: url(:/ui/img/batthern-1920x1080.png);

    background-repeat: no-repeat;
    background-position: center;
    min-width: 1280px;
    min-height: 720px;
}


QWidget#centralWidget {
    background-color: transparent; /* 背景色透明 */
}
QWidget#widget_7{
	background-color: rgba(190,187,182, 0.3); 
}

QWidget#centralWidget {
    background-color: transparent;
    border: none;
    background-clip: border-box;
}


/* 基础按钮样式（适用于所有QPushButton，可通过对象名精准匹配） */
QPushButton {
    /* 主色调配置 */
    background-color: #438483;
    /* 文字样式 */
    color: #FFFFFF;
    font-family: &quot;微软雅黑&quot;;
    font-size: 14px;
    /* 边框与圆角（圆润风格，提升美观度） */
    border: none;
    border-radius: 6px;
    /* 内边距（控制按钮大小，避免文字拥挤） */
    padding: 8px 16px;
}

/* 悬浮状态（鼠标移入，加深色调+轻微放大） */
QPushButton:hover {
    background-color: #366E6D; /* 主色调加深5%，更醒目 */
}

/* 按下状态（鼠标点击，色调更深+下沉效果） */
QPushButton:pressed {
    background-color: #295857; /* 主色调加深10%，反馈点击动作 */
}

/* 选中状态（如单选按钮/复选按钮选中，可选） */
QPushButton:checked {
    background-color: #366E6D;
    border: 2px solid #295857; /* 增加边框，区分选中状态 */
}

/* 禁用状态（按钮不可点击，降低透明度+灰化） */
QPushButton:disabled {
    background-color: rgba(67, 132, 131, 0.5); /* 主色调半透明 */
    color: rgba(255, 255, 255, 0.7);
}

/* 可选：扁平化风格按钮（无阴影，简洁大方） */
QPushButton#FlatButton {
    border-radius: 4px;
}
QPushButton#FlatButton:hover {
    background-color: #366E6D;
}

/* 可选：圆角圆形按钮（适用于图标按钮） */
QPushButton#CircleButton {
    width: 40px;
    height: 40px;
    border-radius: 20px; /* 圆形效果 */
    padding: 0;
    font-size: 16px; /* 图标字体大小 */
}

/* 标题栏窗口按钮样式（兼容低版本QT） */
QPushButton#pushButton_minimize,
QPushButton#pushButton_maximize,
QPushButton#pushButton_39 {
    background-color: transparent;
    border: none;
    width: 32px;
    height: 32px;
}

QPushButton#pushButton_minimize:hover,
QPushButton#pushButton_maximize:hover,
QPushButton#pushButton_39:hover {
    background-color: rgba(255, 255, 255, 1);
    border-radius: 4px;
}

QPushButton#pushButton_minimize:pressed,
QPushButton#pushButton_maximize:pressed,
QPushButton#pushButton_39:pressed {
    background-color: rgba(255, 255, 255, 0.2);
}

/* 正常状态：使用细线条图标 x-thin.svg */
QPushButton#pushButton_39:!hover:!pressed {
    qproperty-icon: url(:/ui/img/x-thin.svg);
    qproperty-iconSize: 24px 24px; /* 图标尺寸，可调整 */
}

/* 悬浮状态：使用填充图标 x-fill.svg（视觉反馈） */
QPushButton#pushButton_39:hover {
    qproperty-icon: url(:/ui/img/x-fill.svg);
    qproperty-iconSize: 24px 24px;
}

/* 按下状态：保持填充图标，加深背景 */
QPushButton#pushButton_39:pressed {
    qproperty-icon: url(:/ui/img/x-fill.svg);
    qproperty-iconSize: 24px 24px;
}

QTabWidget::tab-bar {
    alignment: left; /* 标签左对齐，可选 */
}






/* ========== 1. QComboBox 美化（线条颜色：#438483） ========== */
QComboBox {
    /* 边框（核心：线条颜色设置为#438483） */
    border: 1px solid #438483;
    border-radius: 6px;
    padding: 6px 10px;
    /* 补充基础样式，确保显示正常 */
    background-color: #FFFFFF;
    color: #000000;
    font-family: &quot;微软雅黑&quot;;
    font-size: 14px;
    outline: none;
}

/* 下拉箭头样式（可选，保持线条风格统一） */
QComboBox::down-arrow {
    image: none;
    border-left: 1px solid #438483;
    width: 20px;
    height: 20px;
}

/* 下拉框面板样式（线条颜色统一） */
QComboBox QAbstractItemView {
    border: 1px solid #438483;
    background-color: #FFFFFF;
    outline: none;
}

/* 悬浮状态（线条加深，使用#438483深色系#366E6D） */
QComboBox:hover {
    border-color: #366E6D; /* 主色调加深，提升交互 */
}

/* 禁用状态（线条半透明） */
QComboBox:disabled {
    border-color: rgba(67, 132, 131, 0.5);
    background-color: rgba(255, 255, 255, 0.8);
}

/* ========== 2. QSpinBox 美化（线条颜色：#438483） ========== */
QSpinBox {
    border: 1px solid #438483;
    border-radius: 6px;
    padding: 6px 10px;
    /* 补充基础样式，确保显示正常 */
    background-color: #FFFFFF;
    color: #000000;
    font-family: &quot;微软雅黑&quot;;
    font-size: 14px;
    outline: none;
}

/* 上下箭头按钮样式（线条颜色统一） */
QSpinBox::up-button, QSpinBox::down-button {
    border-left: 1px solid #438483;
    background-color: rgba(67, 132, 131, 0.1);
    width: 20px;
}

/* 箭头图标样式（可选） */
QSpinBox::up-arrow {
    image: none;
    border-bottom: 1px solid #438483;
    width: 8px;
    height: 8px;
}
QSpinBox::down-arrow {
    image: none;
    border-top: 1px solid #438483;
    width: 8px;
    height: 8px;
}

/* 悬浮状态（线条加深） */
QSpinBox:hover {
    border-color: #366E6D;
}

/* 禁用状态 */
QSpinBox:disabled {
    border-color: rgba(67, 132, 131, 0.5);
    background-color: rgba(255, 255, 255, 0.8);
}

/* ========== 3. QTableWidget 美化（线条颜色：#438483） ========== */
QTableWidget {
    border: 1px solid #438483;
    border-radius: 6px;
    gridline-color: #438483; /* 单元格分隔线颜色 */
    outline: none;
    /* 补充基础样式，确保显示正常 */
    background-color: #FFFFFF;
    color: #000000;
    font-family: &quot;微软雅黑&quot;;
    font-size: 14px;
}

/* 表头样式（线条颜色统一） */
QHeaderView::section {
    background-color: rgba(67, 132, 131, 0.2);
    color: #000000;
    border: 1px solid #438483; /* 表头边框线条 */
    padding: 6px;
    text-align: center;
    font-family: &quot;微软雅黑&quot;;
    font-size: 14px;
}

/* 单元格样式 */
QTableWidget::item {
    border: none; /* 避免与网格线重复 */
    padding: 6px;
}

/* 单元格选中状态（与主色调配套） */
QTableWidget::item:selected {
    background-color: #438483 !important;
    color: #FFFFFF !important;
}

/* 垂直滚动条（可选，线条颜色统一） */
QScrollBar:vertical {
    border-left: 1px solid #438483;
    background-color: #FFFFFF;
    width: 12px;
}
QScrollBar::handle:vertical {
    background-color: #438483;
    border-radius: 6px;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    border: none;
    background: transparent;
}

/* 水平滚动条（可选，线条颜色统一） */
QScrollBar:horizontal {
    border-top: 1px solid #438483;
    background-color: #FFFFFF;
    height: 12px;
}
QScrollBar::handle:horizontal {
    background-color: #438483;
    border-radius: 6px;
}
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    border: none;
    background: transparent;
}

/* ========== QDateTimeEdit 美化（与QSpinBox样式完全一致，线条颜色：#438483） ========== */
QDateTimeEdit {
    /* 与QSpinBox完全一致的边框、圆角、内边距 */
    border: 1px solid #438483;
    border-radius: 6px;
    padding: 6px 10px;
    /* 保留基础样式，与QSpinBox视觉统一 */
    background-color: #FFFFFF;
    color: #000000;
    font-family: &quot;微软雅黑&quot;;
    font-size: 14px;
    outline: none;
}

/* 上下箭头按钮样式（与QSpinBox完全一致） */
QDateTimeEdit::up-button, QDateTimeEdit::down-button {
    border-left: 1px solid #438483;
    background-color: rgba(67, 132, 131, 0.1);
    width: 20px;
}

/* 箭头图标样式（与QSpinBox完全一致，纯边框模拟箭头） */
QDateTimeEdit::up-arrow {
    image: none;
    border-bottom: 1px solid #438483;
    width: 8px;
    height: 8px;
}
QDateTimeEdit::down-arrow {
    image: none;
    border-top: 1px solid #438483;
    width: 8px;
    height: 8px;
}

/* 悬浮状态（与QSpinBox完全一致） */
QDateTimeEdit:hover {
    border-color: #366E6D;
}

/* 禁用状态（与QSpinBox完全一致） */
QDateTimeEdit:disabled {
    border-color: rgba(67, 132, 131, 0.5);
    background-color: rgba(255, 255, 255, 0.8);
}

/* 可选：下拉日历面板样式（保持线条风格统一，不破坏QSpinBox同步性） */
QDateTimeEdit QCalendarWidget {
    border: 1px solid #438483;
    background-color: #FFFFFF;
    outline: none;
}
QDateTimeEdit QCalendarWidget QHeaderView::section {
    background-color: rgba(67, 132, 131, 0.2);
    border: 1px solid #438483;
    padding: 6px;
}
QDateTimeEdit QCalendarWidget QAbstractItemView::item:selected {
    background-color: #438483;
    color: #FFFFFF;
}





