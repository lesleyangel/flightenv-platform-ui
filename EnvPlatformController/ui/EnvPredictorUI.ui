/* ========== 5. QGroupBox 美化（线条颜色：#438483） ========== */
QGroupBox {
    font-family: &quot;微软雅黑&quot;;
    font-size: 14px;
    font-weight: 500;
    color: #000000;
    border: 1px solid #438483;
    border-radius: 6px;
    background-color: #EEEAE3;
    padding-top: 18px;
    padding-left: 10px;
    padding-right: 10px;
    padding-bottom: 10px;
    margin-top: 10px;
}

QGroupBox::title {
    /* 完全保留原始样式的布局属性，未做任何修改 */
    subcontrol-origin: margin;
    /* 仅修改字体颜色（此处替换为需要的颜色，示例用#2D5A59，可自行修改） */
    color: #2D5A59; 
    padding: 0 10px;
    /* 核心：仅将透明背景改为与QGroupBox一致的背景，解决边框遮挡问题，不改变布局 */
    background-color: #EEEAE3;
}

QGroupBox:hover {
    border-color: #366E6D;
    /* 悬浮状态下标题字体颜色可按需修改，若不需要变化可删除此内部样式 */
    QGroupBox::title {
        color: #254B4A; /* 悬浮时标题字体颜色，可自定义 */
        background-color: #EEEAE3; /* 保持背景一致，不改变布局 */
    }
}

QGroupBox:disabled {
    border-color: rgba(67, 132, 131, 0.5);
    background-color: rgba(238, 234, 227, 0.8);
    color: rgba(0, 0, 0, 0.5);
    QGroupBox::title {
        /* 禁用状态下标题字体颜色修改（示例用rgba(45, 90, 89, 0.5)，可自定义） */
        color: rgba(45, 90, 89, 0.5);
        background-color: rgba(238, 234, 227, 0.8); /* 保持背景一致，不改变布局 */
    }
}


/* 整体控制QTabWidget样式 */
QTabWidget {
    font-size: 13px;          /* 统一标签文字大小，与图标协调 */
    color: #2c3e50;           /* 默认文字颜色 */
    border: none;             /* 隐藏外层边框，更简洁 */
}


/* 设置所有QLabel的字体颜色为白色 */
QLabel {
    color: rgba(0,0,0,1); /* 纯白色，也可使用rgba(255,255,255,1)设置不透明白色 */
    /* 可选：继承全局字体样式，保持与其他控件一致 */
    font-family: &quot;微软雅黑&quot;;
    font-size: 14px;
}

/* 可选：针对特定对象名的QLabel设置白色字体（精准控制，不影响所有QLabel） */
QLabel#label_username, QLabel#label_title {
    color: #FFFFFF;
    font-weight: bold; /* 可选：加粗突出 */
}

/* 可选：禁用状态下的QLabel白色字体（半透明效果） */
QLabel:disabled {
    color: rgba(255, 255, 255, 0.7); /* 禁用时白色半透明，更美观 */
}


